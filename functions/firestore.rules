rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact form submissions - initially allow public writes for development
    match /contactFormSubmissions/{submissionId} {
      // Anyone can create a submission (public form)
      allow create: if true;
      
      // Only allow reads by authenticated admin users in the future
      // TODO: Implement Firebase Authentication and App Check before production
      allow read: if false; // For initial development, no public reads
      
      // No updates or deletes from clients
      allow update, delete: if false;
    }
    
    // Future client portal integration
    // TODO: Uncomment and customize when implementing client portal
    /*
    match /clients/{clientId} {
      // Only allow access to authenticated users who own the data
      allow read, write: if request.auth != null && request.auth.uid == clientId;
      
      // Client document library - nested collection
      match /documentLibrary/{documentId} {
        allow read: if request.auth != null && request.auth.uid == clientId;
      }
    }
    */
  }
} 